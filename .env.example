# Snipe-IT Environment Configuration
# Copy this to .env and update with your values

# Application
APP_ENV=production
APP_DEBUG=false
APP_KEY=
# Generate APP_KEY with: docker run --rm snipe/snipe-it php artisan key:generate --show

# Database
MYSQL_ROOT_PASSWORD=change_me_root_password
SNIPEIT_DB_PASSWORD=change_me_secure_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# Mail Configuration (Optional)
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDR=
MAIL_FROM_NAME=Snipe-IT

# Session & Cache
SESSION_DRIVER=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
